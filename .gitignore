# =============================================================================
# Sports Betting Arbitrage Scanner - .gitignore
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Rope
.ropeproject

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# pdm
.pdm.toml
.pdm-python
.pdm-build/

# Project-specific runtime artifacts
# Keep data/ directory structure via data/.gitkeep, but ignore generated outputs
data/arbs.json
data/arb_history.jsonl
data/*.json
data/*.jsonl

# Logs
logs/
*.log

# Playwright
playwright/.cache/

# OS generated
.DS_Store
Thumbs.db
desktop.ini

# Secrets / keys (defense in depth)
*.pem
*.key
secrets/
*.token
